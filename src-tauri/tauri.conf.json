{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "IconForge",
  "version": "0.1.0",
  "identifier": "com.iconforge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "IconForge",
        "width": 1600,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 浪花穿石",
    "publisher": "silas",
    "resources": [],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
